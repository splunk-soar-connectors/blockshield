            "description": "Retrieve threat intelligence information about an IP address",
            "type": "investigate",
            "read_only": true,
            "parameters": {
                "ip": {
                    "description": "IP address to look up",
                    "data_type": "string",
                    "required": true,
                    "primary": true,
                    "contains": ["ip"],
                    "order": 0
